generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model menu {
  id        Int         @id @default(autoincrement())
  name      String
  price     Int
  category  String
  stock     Int         @default(0)
  createdAt DateTime    @default(now())
  orderitem orderitem[]
}

model order {
  id        Int          @id @default(autoincrement())
  tableId   Int
  total     Decimal      @db.Decimal(10, 2)
  status    order_status @default(PENDING)
  createdAt DateTime     @default(now())
  table     table        @relation(fields: [tableId], references: [id], map: "Order_tableId_fkey")
  orderitem orderitem[]
  payment   payment?

  @@index([tableId], map: "Order_tableId_fkey")
}

model orderitem {
  id       Int     @id @default(autoincrement())
  orderId  Int
  menuId   Int
  quantity Int
  price    Decimal @db.Decimal(10, 2)
  menu     menu    @relation(fields: [menuId], references: [id], map: "OrderItem_menuId_fkey")
  order    order   @relation(fields: [orderId], references: [id], map: "OrderItem_orderId_fkey")

  @@index([menuId], map: "OrderItem_menuId_fkey")
  @@index([orderId], map: "OrderItem_orderId_fkey")
}

model payment {
  id         Int      @id @default(autoincrement())
  orderId    Int      @unique(map: "Payment_orderId_key")
  total      Decimal  @db.Decimal(10, 2)
  paidAmount Decimal  @db.Decimal(10, 2)
  change     Decimal  @db.Decimal(10, 2)
  method     String
  createdAt  DateTime @default(now())
  order      order    @relation(fields: [orderId], references: [id], map: "Payment_orderId_fkey")
}

model table {
  id         Int      @id @default(autoincrement())
  number     Int      @unique(map: "Table_number_key")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  isOccupied Boolean  @default(false)
  order      order[]
}

model user {
  id        Int       @id @default(autoincrement())
  username  String    @unique(map: "User_username_key")
  password  String
  role      user_role @default(CASHIER)
  createdAt DateTime  @default(now())
}

enum order_status {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
}

enum user_role {
  ADMIN
  CASHIER
}
